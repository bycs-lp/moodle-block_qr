{{!
    @template block_qr/mode_geolocation

    Template for displaying geolocation information in the QR block.

    Example context (json):
    {
        "description": "Location",
        "geocoordinates": "48.137, 11.575",
        "qrurl": true,
        "qrcodelink": "https://www.openstreetmap.org/?mlat=48.137&mlon=11.575"
    }
}}
<p class="text-center">
    {{description}}<br>
    {{#geocoordinates}}
        <i class="fa fa-map-marker"></i>
        {{#qrurl}}<a href="{{{qrcodelink}}}">{{/qrurl}}
        {{geocoordinates}}
        {{#qrurl}}</a>{{/qrurl}}
    {{/geocoordinates}}
</p>
