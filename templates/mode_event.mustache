{{!
    @template block_qr/mode_event

    Template for displaying calendar event details in the QR block.

    Example context (json):
    {
        "calendarsummary": "Hackathon",
        "calendarlocation": "HS06",
        "calendarstart": "15.10.2025 - ",
        "calendarend": "17.10.2025"
    }
}}
<hr>
<p class="text-center">
    {{#calendarsummary}}{{calendarsummary}}<br>{{/calendarsummary}}
    {{#calendarlocation}}<i class="fa fa-map-marker"></i> {{calendarlocation}}<br>{{/calendarlocation}}
    <i class="fa fa-calendar"></i> {{calendarstart}}{{calendarend}}
</p>
