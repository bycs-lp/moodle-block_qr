{{!
    @template block_qr/mode_wifi

    Template for displaying WiFi network details in the QR block.

    Example context (json):
    {
        "wifissid": "SchoolNet",
        "wifiauthentication": "WPA",
        "wifipasskey": "secret"
    }
}}
<p class="text-left">
    <b>{{#str}}ssid_label, block_qr{{/str}}:</b> {{{wifissid}}}<br>
    <b>{{#str}}config_wifiauthentication, block_qr{{/str}}:</b> {{{wifiauthentication}}}<br>
    <b>{{#str}}passkey_label, block_qr{{/str}}:</b> {{{wifipasskey}}}
</p>
